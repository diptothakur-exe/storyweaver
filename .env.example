# ─── StoryWeaver Environment Variables ────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Supabase (for save/load) ──────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://feobpiykhwqafvfumtia.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_Cc5IL6w0dT0snkdUJ9AN8Q_cQmtdNPy

# ─── OpenRouter (AI generation) ────────────────────────────────────────────────
# Get your key from: https://openrouter.ai/keys
# SERVER-SIDE ONLY — never prefix with VITE_ (would expose to browser)
OPENROUTER_API_KEY=VITE_sk-or-v1-8b3836eae0813ff116d284e43666b0aa773fa6580716db9810729665d38b9929

# Optional: override the AI model. Free models that work well:
#   meta-llama/llama-3-8b-instruct:free
#   mistralai/mistral-7b-instruct:free
#   google/gemma-2-9b-it:free
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# ─── Site metadata (used in OpenRouter referrer header) ────────────────────────
YOUR_SITE_URL=https://storyweaverapp.vercel.app/

# ─── Optional: override API base URL ──────────────────────────────────────────
# Leave empty to use relative /api/* path (correct for Vercel)
# Set to http://localhost:3001 if running API separately
VITE_API_BASE_URL=
